NODE_ENV=production
PORT=3000
DATABASE_URL=postgresql://worldnew:worldnew@postgres:5432/worldnew
NEXT_PUBLIC_APP_URL=http://localhost:3000
SESSION_COOKIE_SECURE=false

# WordPress / WooCommerce integration
WORDPRESS_BASE_URL=http://localhost:10019
WORDPRESS_LOGIN_URL=http://localhost:10019/my-account/
WORDPRESS_CHECKOUT_URL=http://localhost:10019/checkout/
# This is called from inside the app container, so use host.docker.internal
WORDPRESS_AUTH_API_URL=http://host.docker.internal:10019/wp-json/worldnew/v1/auth/login
WORDPRESS_SSO_SECRET=replace-me

# Optional fallback WooCommerce product IDs if not stored in membership_plans
WORDPRESS_PRODUCT_DAY_PASS=
WORDPRESS_PRODUCT_MONTHLY=
WORDPRESS_PRODUCT_ANNUAL=
